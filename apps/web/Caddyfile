# Caddyfile for production static file serving
# This file is built into the production Docker image.

:80 {
	# Serve static files from the /srv directory
	root * /srv
	
	# Enable compression for better performance
	encode gzip zstd
	
	# Enable static file serving
	file_server
	
	# React Router client-side routing fallback
	# If a requested path doesn't correspond to a file, serve index.html
	try_files {path} /index.html
}
