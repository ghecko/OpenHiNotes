FROM node:20-alpine

WORKDIR /app

# Copy package definition
COPY package*.json ./

# Install dependencies (this layer is cached until package.json changes)
RUN npm install

# Expose Vite's default development port
EXPOSE 5173

# Run Vite dev server, binding to all interfaces so it's accessible outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
